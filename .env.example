# Optional: signed macOS builds.
# T3CODE_APPLE_TEAM_ID=ABC1234567
# T3CODE_MACOS_PROVISIONING_PROFILE=/absolute/path/to/t3code.provisionprofile

# Optional URL of an externally-hosted relay. Only the mobile agent-awareness
# push/live-activity lane still reads this; the in-repo relay worker was removed
# along with T3 Connect. Leave unset to keep that lane inert.
# T3CODE_RELAY_URL=https://relay.example.com

# Optional Jarvis Cockpit MCP resource URL. This is the public resource identifier
# that Cockpit injects into Codex as mcp_servers.jarvis.url=<resource>/mcp.
# JARVIS_MCP_RESOURCE_URL=http://127.0.0.1:8795

# Optional Jarvis live-update tuning. SSE is enabled unless explicitly disabled;
# the polling and retained-history values below show their defaults.
# JARVIS_EVENTS_SSE_ENABLED=true
# JARVIS_COCKPIT_POLL_INTERVAL=2
# JARVIS_SESSION_HISTORY_MAX_ITEMS=2000
# JARVIS_SESSION_HISTORY_MAX_SESSIONS=200

# Public, ingest-only mobile OpenTelemetry configuration.
# T3CODE_MOBILE_OTLP_TRACES_URL=https://api.axiom.co/v1/traces
# T3CODE_MOBILE_OTLP_TRACES_DATASET=t3-code-mobile-traces-dev
# T3CODE_MOBILE_OTLP_TRACES_TOKEN=xaat-...
